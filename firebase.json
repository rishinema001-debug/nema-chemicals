{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/dist-electron/**",
      "**/originals_backup/**",
      "main.js",
      "preload.js",
      "admin.html",
      "admin.js",
      "admin.css",
      "package.json",
      "package-lock.json",
      "*.sh",
      "*.py",
      "check_errors.js",
      "fetch_images.js",
      "fix_hindi.js",
      "test_fetch.js",
      "generate-image-index.js",
      "restored_products.json",
      "build/**"
    ],
    "headers": [
      {
        "source": "/sw.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/products.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, max-age=0"
          }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|png|gif|webp|svg)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=604800"
          }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      }
    ]
  },
  "database": {
    "rules": "database.rules.json"
  }
}
